# ==================================================
# SERVIÇO
# ==================================================
SERVICE_ID=16
SERVICE_NAME=group-a-api
PORT=3000

# URL pública (via nginx/load balancer)
SERVICE_URL=http://grupo-a-loadbalancer:80
CONTACT_EMAIL=grupo-a@ufv.br

# ==================================================
# CORE (IMPORTANTE: rede docker interna)
# ==================================================
CORE_SERVICE_URL=http://host.docker.internal:8080
CORE_API_KEY=rfk_15b3dfc8ba5fd480ebf99ec82760b1a8

# Timeout de fallback com Core
CORE_AUCTION_TIMEOUT_SECONDS=10

# ==================================================
# RABBITMQ (container interno)
# ==================================================
RABBITMQ_URL=amqp://localhost:5673

# ==================================================
# BANCO DE DADOS
# ==================================================
DB_HOST=grupo-a-postgres
DB_PORT=5432
DB_NAME=ridefleet
DB_USER=postgres
DB_PASSWORD=postgres

# ==================================================
# PARCEIROS (OUTROS GRUPOS)
# IMPORTANTE: nomes DEVEM bater com docker network
# ==================================================
PARTNERS=grupo-b:http://grupo-a-api-2:3000,grupo-c:http://grupo-a-api-1:3000

# ==================================================
# LOAD BALANCER / NGINX COMPAT
# ==================================================
LOAD_BALANCER_URL=http://grupo-a-loadbalancer:80

# ==================================================
# REGRAS DE NEGÓCIO
# ==================================================
MAX_LOCAL_RIDES=5
AUCTION_TIMEOUT_MS=3000

# ==================================================
# CIRCUIT BREAKER
# ==================================================
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT_MS=10000

# ==================================================
# FILA / PERFORMANCE
# ==================================================
QUEUE_MAX_SIZE=100
QUEUE_BATCH_SIZE=3
QUEUE_STEP_MS=9000

# ==================================================
# OBSERVABILIDADE
# ==================================================
METRICS_ENABLED=true
LOG_LEVEL=info