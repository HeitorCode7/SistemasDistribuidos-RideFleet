# ==============================
# Configuração do serviço
# ==============================

# Nome/ID deste serviço (ex: grupo-a, grupo-b)
SERVICE_ID=grupo-a

# Porta do servidor HTTP
PORT=3000

# ==============================
# Parceiros (outros grupos)
# Separe múltiplos parceiros por vírgula
# Formato: id:url,id:url
# ==============================
PARTNERS=grupo-b:http://localhost:3001,grupo-c:http://localhost:3002

# ==============================
# Configurações de negócio
# ==============================

# Máximo de corridas locais antes de delegar
MAX_LOCAL_RIDES=5

# Timeout para leilão (ms)
AUCTION_TIMEOUT_MS=3000

# ==============================
# Circuit Breaker
# ==============================
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT_MS=10000

# ==============================
# Distributed Lock
# ==============================
LOCK_TTL_MS=5000
